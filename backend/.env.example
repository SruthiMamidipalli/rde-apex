# Copy to backend/.env and fill in. Without AWS creds the API runs in
# DEGRADED mode (deterministic, no-Bedrock output) — the dashboard is still
# fully populated for a demo.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional (STS/temporary credentials):
AWS_SESSION_TOKEN=

# Bedrock cross-region INFERENCE PROFILE IDs (bare model IDs are rejected for
# on-demand Claude 4 models). Defaults below are validated invokable profiles.
BEDROCK_MODEL_HEAVY=global.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_MODEL_LIGHT=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Scoring / agent thresholds
CHURN_THRESHOLD=50
ESCALATION_VALUE_THRESHOLD=50
WORKFLOW_TIMEOUT_SECONDS=30

# Force deterministic mode even if creds are present (useful for tests/demos):
FORCE_DEGRADED=false
